{
    "name": "supercord",
    "productName": "Supercord",
    "desktopName": "supercord",
    "version": "3.2.1",
    "private": true,
    "description": "Supercord is a custom Discord desktop app",
    "keywords": [],
    "homepage": "https://supercord.org",
    "license": "GPL-3.0-or-later",
    "author": "Supercord <contact@supercord.org>",
    "main": "dist/js/main.js",
    "scripts": {
        "build": "bun run scripts/build/build.mts",
        "build:patcher": "bun build scripts/patcher/index.ts --compile --outfile dist/SupercordPatcher",
        "build:dev": "bun run build --dev",
        "buildLibVesktop": "bun install --cwd packages/libvesktop && bun run --cwd packages/libvesktop build",
        "compileArrpc": "bun run scripts/build/compileArrpc.mts",
        "package": "bun run build && electron-builder",
        "package:dir": "bun run build && electron-builder --dir",
        "lint": "eslint",
        "lint:fix": "bun lint --fix",
        "start": "cd Supercord-core && pnpm install && pnpm build && cd .. && bun run build && electron .",
        "start:dev": "cd Supercord-core && pnpm install && pnpm build && cd .. && bun run build:dev && electron .",
        "start:watch": "bun run build:dev && bun run scripts/startWatch.mts",
        "test": "bun lint && bun testTypes",
        "testTypes": "tsc --noEmit",
        "watch": "bun run build --watch",
        "generateMeta": "bun run scripts/utils/generateMeta.mts",
        "updateArrpcDB": "bun ./node_modules/arrpc-bun/scripts/update_db.ts",
        "postinstall": "bun updateArrpcDB && bun compileArrpc"
    },
    "dependencies": {
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "arrpc-bun": "^1.4.0",
        "electron-updater": "^6.8.3",
        "tsutils": "^3.21.0",
        "ws": "^8.21.0"
    },
    "optionalDependencies": {
        "@vencord/venmic": "^6.1.0"
    },
    "devDependencies": {
        "@equicord/types": "^1.14.2",
        "@fal-works/esbuild-plugin-global-externals": "^2.1.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.9.1",
        "@types/react": "19.2.9",
        "dotenv": "^17.4.2",
        "electron": "^41.7.1",
        "electron-builder": "^26.8.1",
        "esbuild": "^0.27.7",
        "eslint": "^10.4.1",
        "eslint-import-resolver-alias": "^1.1.2",
        "eslint-plugin-path-alias": "^2.1.0",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-simple-header": "^1.2.2",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "libvesktop": "file:packages/libvesktop",
        "prettier": "^3.8.3",
        "source-map-support": "^0.5.21",
        "tsx": "^4.22.3",
        "type-fest": "^5.6.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "xml-formatter": "^3.7.0"
    },
    "engines": {
        "bun": ">=1.3.0"
    },
    "build": {
        "appId": "org.supercord.desktop",
        "productName": "Supercord",
        "executableName": "supercord",
        "files": [
            "!*",
            "!node_modules",
            "dist/js",
            "static",
            "package.json",
            "LICENSE"
        ],
        "protocols": {
            "name": "Discord",
            "schemes": [
                "discord"
            ]
        },
        "beforePack": "scripts/build/beforePack.mjs",
        "afterPack": "scripts/build/afterPack.mjs",
        "linux": {
            "icon": "build/icon.svg",
            "category": "Network",
            "maintainer": "contact@supercord.org",
            "target": [
                {
                    "target": "deb",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "tar.gz",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "rpm",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "AppImage",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "desktop": {
                "entry": {
                    "Name": "Supercord",
                    "GenericName": "Internet Messenger",
                    "Type": "Application",
                    "Categories": "Network;InstantMessaging;Chat;",
                    "Keywords": "discord;vencord;electron;chat;supercord",
                    "MimeType": "x-scheme-handler/discord",
                    "StartupWMClass": "supercord"
                }
            }
        },
        "mac": {
            "target": [
                {
                    "target": "default",
                    "arch": "universal"
                }
            ],
            "category": "public.app-category.social-networking",
            "darkModeSupport": true,
            "extendInfo": {
                "NSMicrophoneUsageDescription": "This app needs access to the microphone",
                "NSCameraUsageDescription": "This app needs access to the camera",
                "com.apple.security.device.audio-input": true,
                "com.apple.security.device.camera": true,
                "CFBundleIconName": "Icon"
            },
            "notarize": true
        },
        "dmg": {
            "background": "build/background.tiff",
            "icon": "build/icon.icns",
            "iconSize": 105,
            "window": {
                "width": 512,
                "height": 340
            },
            "contents": [
                {
                    "x": 140,
                    "y": 160
                },
                {
                    "x": 372,
                    "y": 160,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "nsis": {
            "include": "build/installer.nsh",
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "win": {
            "icon": "build/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ]
        },
        "publish": {
            "provider": "github"
        },
        "rpm": {
            "fpm": [
                "--rpm-rpmbuild-define=_build_id_links none"
            ]
        },
        "electronFuses": {
            "runAsNode": false,
            "enableCookieEncryption": false,
            "enableNodeOptionsEnvironmentVariable": false,
            "enableNodeCliInspectArguments": false,
            "enableEmbeddedAsarIntegrityValidation": false,
            "onlyLoadAppFromAsar": true,
            "loadBrowserProcessSpecificV8Snapshot": false,
            "grantFileProtocolExtraPrivileges": false
        }
    },
    "trustedDependencies": [
        "@vencord/venmic",
        "electron",
        "electron-winstaller",
        "esbuild"
    ]
}
